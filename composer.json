{
  "name": "hicham/examapp-v3",
  "description": "Plateforme d'examens scolaires haute performance",
  "type": "project",
  "require": {
    "php": "^8.2",
    "dompdf/dompdf": "^3.0",
    "phpoffice/phpspreadsheet": "^2.1",
    "symfony/var-dumper": "^7.2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@php -r \"if (!file_exists('.env') && file_exists('.env.example')) copy('.env.example', '.env');\""
    ]
  }
}